generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int           @id @default(autoincrement())
  name            String?
  email           String        @unique
  password        String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @default(now()) @updatedAt
  role            String        @default("user")
  isVerified      Boolean       @default(false)
  verificationToken String?
  address         String?
  city            String?
  dateOfBirth     DateTime?
  phone           String?
  bsn             String?
  isBlocked       Boolean       @default(false)
  
  reservations    Reservation[] @relation("ClientReservations")
  assignedLessons Reservation[] @relation("InstructorReservations")
  schedules       LessonSchedule[] @relation("InstructorSchedule")

  @@map("users")
}

model Reservation {
  id             Int        @id @default(autoincrement())
  userId         Int        @map("user_id")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @default(now()) @updatedAt
  lesson         LessonType
  bookingDate    DateTime   @default(now()) @map("booking_date")
  price          Float
  
  status         String     @default("VOORLOPIG")
  location       String?
  duoName        String?
  duoAddress     String?
  duoCity        String?
  duoPhone       String?
  hasPaid        Boolean    @default(false)
  cancelReason   String?
  cancelApproved Boolean    @default(false)
  
  instructorId   Int?       @map("instructor_id")

  user           User       @relation("ClientReservations", fields: [userId], references: [id])
  instructor     User?      @relation("InstructorReservations", fields: [instructorId], references: [id])

  @@map("reservations")
}

enum LessonType {
  PRIVE_LES
  LOSSE_DUO_LES
  DUO_PAKKET_3
  DUO_PAKKET_5
}

model LessonSchedule {
  id           Int      @id @default(autoincrement())
  date         DateTime
  time         String
  instructorId Int      @map("instructor_id")
  instructor   User     @relation("InstructorSchedule", fields: [instructorId], references: [id])
  maxPersons   Int      @default(2) @map("max_persons")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@unique([date, time, instructorId])
  @@map("lesson_schedules")
}
